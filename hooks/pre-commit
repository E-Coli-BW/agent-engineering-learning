#!/usr/bin/env bash
# ============================================================
# Git pre-commit hook — 自动 Code Review
# ============================================================
# 安装: cp hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# 或者: ./hooks/install.sh
# ============================================================

ROOT_DIR="$(git rev-parse --show-toplevel)"

echo "🔍 Running Code Review..."

# 1. Python Code Review
PYTHONPATH="$ROOT_DIR" python "$ROOT_DIR/project/review/reviewer.py" --hook
REVIEW_EXIT=$?

if [ $REVIEW_EXIT -ne 0 ]; then
    echo ""
    echo "❌ Code Review 发现 error，请修复后重新 commit"
    echo "   跳过检查: git commit --no-verify"
    exit 1
fi

# 2. 运行 Python 测试 (只跑快速测试，不跑 benchmark)
echo "🧪 Running tests..."
cd "$ROOT_DIR"
PYTHONPATH=. python -m pytest tests/ --tb=line -q 2>&1
TEST_EXIT=$?

if [ $TEST_EXIT -ne 0 ]; then
    echo ""
    echo "❌ 测试失败，请修复后重新 commit"
    echo "   跳过检查: git commit --no-verify"
    exit 1
fi

echo "✅ Pre-commit checks passed"
