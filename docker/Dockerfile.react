# ============================================================
# ReAct Agent Dockerfile
# ============================================================
# Build:  docker build -f docker/Dockerfile.react -t agent-react .
# Run:    docker run -p 5002:5002 --env OLLAMA_URL=http://host.docker.internal:11434 agent-react
# ============================================================

FROM python:3.12-slim

WORKDIR /app

COPY docker/requirements-server.txt .
RUN pip install --no-cache-dir -r requirements-server.txt

COPY project/ project/
COPY data/project_chroma_db/ data/project_chroma_db/

ENV OLLAMA_URL=http://host.docker.internal:11434
ENV OLLAMA_BASE_URL=http://host.docker.internal:11434
ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1

EXPOSE 5002

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:5002/health')" || exit 1

CMD ["python", "project/react_agent.py", "--serve"]
