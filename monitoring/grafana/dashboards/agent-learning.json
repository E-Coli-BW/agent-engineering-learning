{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "服务状态",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" } , "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "title": "Gateway — 请求 QPS (按路由)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(gateway_requests_total[1m])",
          "legendFormat": "{{route}} ({{status}})"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "title": "Gateway — 请求延迟 (按路由)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "rate(gateway_request_duration_seconds_sum[1m]) / rate(gateway_request_duration_seconds_count[1m])",
          "legendFormat": "avg {{route}}"
        },
        {
          "expr": "gateway_request_duration_seconds_max",
          "legendFormat": "max {{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "title": "RAG — 请求计数 (成功/失败)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "rag_requests_total",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 20 } }
      }
    },
    {
      "title": "RAG — 延迟百分位",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "targets": [
        {
          "expr": "rag_request_duration_ms{quantile=\"0.5\"}",
          "legendFormat": "P50"
        },
        {
          "expr": "rag_request_duration_ms{quantile=\"0.95\"}",
          "legendFormat": "P95"
        },
        {
          "expr": "rag_request_duration_ms{quantile=\"0.99\"}",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "title": "RAG — 向量库大小 & 错误率",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "targets": [
        {
          "expr": "rag_vector_count",
          "legendFormat": "向量数"
        },
        {
          "expr": "rag_error_rate",
          "legendFormat": "错误率"
        },
        {
          "expr": "rag_uptime_seconds / 3600",
          "legendFormat": "运行时间(h)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      }
    },
    {
      "title": "Gateway JVM — 堆内存使用",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"} / 1024 / 1024",
          "legendFormat": "Used ({{id}})"
        },
        {
          "expr": "jvm_memory_max_bytes{area=\"heap\"} / 1024 / 1024",
          "legendFormat": "Max ({{id}})"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "decmbytes", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "title": "Gateway JVM — GC 暂停",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum[1m])",
          "legendFormat": "GC pause {{action}} {{cause}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["agent-learning", "gateway", "rag"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Agent Learning — 全栈监控",
  "uid": "agent-learning-main",
  "version": 1
}
